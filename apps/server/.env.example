# Collective server — environment configuration
#
# SETUP: copy this file to `.env` in this directory (apps/server/.env) and
# uncomment what you need — it is loaded automatically at server start (repo
# root `.env` works too). Real environment variables always take precedence.
#
# With NOTHING set, the server runs fully self-contained on mock adapters:
# deterministic transcription + heuristic summaries, no data leaves the machine.

# Port (default 4000)
#PORT=4000

# Where durable data lives: meeting state (state.json), the append-only audit
# journal (audit.jsonl), and per-meeting audio files (audio/). Defaults to
# apps/server/.data — git-ignored, survives restarts. Deleting the folder is a
# full reset.
#COLLECTIVE_DATA_DIR=

# --- AssemblyAI (design-spec §2.2; execute the BAA first — issue #6 / CP-1) ---
# Setting the key switches transcription (async + memo Sync API) to the real vendor.
#ASSEMBLYAI_API_KEY=

# --- BAA registry seed (dev store is in-memory, so Admin toggles reset on
# restart; this seeds them from the file instead). ONLY list a vendor after
# its BAA is actually signed (docs/procurement-baa-runbook.md).
# Comma list of: assemblyai, awsBedrock, claudeWorkspace, microsoft
#COLLECTIVE_BAA=assemblyai

# Set to 0 to treat meetings with an unanswered "Contains patient info?" chip
# as non-PHI (default is the fail-safe: unanswered = treated as flagged).
#COLLECTIVE_PHI_FAILSAFE=0

# --- Claude on Amazon Bedrock (design-spec §6.5; Q5 resolution; issue #7 / CP-2) ---
# Uses the standard AWS credential chain (env/profile/role). Set BEDROCK_DISABLED=1
# to force the mock even when AWS credentials are present.
#AWS_PROFILE=
#BEDROCK_MODEL_ID=anthropic.claude-sonnet-5
#BEDROCK_DISABLED=1

# --- Microsoft Entra ID sign-in + Graph calendar (backlog ID-1 / AT-3) ---
# App registration in entra.microsoft.com (single tenant; Web redirect URI
# http://localhost:4000/auth/callback; delegated permissions: openid, profile,
# email, offline_access, User.Read, Calendars.Read; admin consent granted).
# With these set, the login page shows "Sign in with Microsoft" and untitled
# captures are named from the signed-in user's Outlook calendar.
#GRAPH_TENANT_ID=
#GRAPH_CLIENT_ID=
#GRAPH_CLIENT_SECRET=
# Override only for non-default hosts:
#GRAPH_REDIRECT_URI=http://localhost:4000/auth/callback
#WEB_ORIGIN=http://localhost:5173
