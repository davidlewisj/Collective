{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllServicesOutsidePhiAllowlist",
      "Effect": "Deny",
      "NotAction": [
        "s3:*",
        "rds:*",
        "rds-db:*",
        "es:*",
        "aoss:*",
        "kms:*",
        "kinesis:*",
        "secretsmanager:*",
        "bedrock:*",
        "cloudwatch:*",
        "logs:*",
        "events:*",
        "sns:*",
        "sqs:*",
        "xray:*",
        "ecs:*",
        "ecr:*",
        "lambda:*",
        "application-autoscaling:*",
        "ec2:*",
        "elasticloadbalancing:*",
        "acm:*",
        "route53:*",
        "iam:*",
        "sts:*",
        "access-analyzer:*",
        "cloudformation:*",
        "ssm:*",
        "config:*",
        "cloudtrail:*",
        "backup:*",
        "backup-storage:*",
        "guardduty:*",
        "securityhub:*",
        "artifact:*",
        "support:*",
        "health:*",
        "budgets:*",
        "ce:*",
        "tag:*",
        "resource-groups:*",
        "organizations:Describe*",
        "organizations:List*"
      ],
      "Resource": "*"
    }
  ]
}
